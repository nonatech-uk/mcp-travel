# MCP transport — pick one
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8080

# Public-repo defaults: contact email used in HTTP User-Agent strings to
# upstream APIs (Entur, ViaggiaTreno, DB, iRail, Nominatim) and the default
# origin used by `travel_plan_trip` when called without an explicit origin.
MCP_TRAVEL_CONTACT=mcp-travel@example.com
MCP_TRAVEL_DEFAULT_ORIGIN=London, UK
MCP_TRAVEL_DEFAULT_ORIGIN_LABEL=London (default)

# Postgres (mcp-travel cache + journey log). Optional — caching/audit fail-soft if missing.
TRAVEL_DB_DSN=postgresql://travel:CHANGEME@postgres:5432/travel
TRAVEL_DB_SSLMODE=disable

# Read-only Postgres for mylocation.place lookups (named-place resolution).
# Optional. If unset, `forward_geocode` falls back to travel.geocode_cache + Nominatim.
MCP_READONLY_PASSWORD=

# Flights — Duffel (https://duffel.com)
DUFFEL_API_TOKEN=duffel_test_xxxxxxxxxxxxxxxx
DUFFEL_MODE=test

# Drive times — Google Maps Routes API
GOOGLE_MAPS_API_KEY=

# Hotels — LiteAPI (https://liteapi.travel)
LITEAPI_API_KEY=

# Geocoding — Nominatim. UA must include a contact per OSM policy.
NOMINATIM_USER_AGENT=mcp-travel ($MCP_TRAVEL_CONTACT)

# UK rail — RTT next-gen API (https://api-portal.rtt.io)
RTT_BEARER_TOKEN=

# UK rail — Transport API station search (https://transportapi.com)
TRANSPORT_API_APP_ID=
TRANSPORT_API_APP_KEY=

# Swiss rail — transport.opendata.ch (no auth)
SBB_API_URL=https://transport.opendata.ch/v1

# French rail — SNCF Navitia (https://numerique.sncf.com)
SNCF_API_KEY=

# Dutch rail — NS Reisinformatie API (https://apiportal.ns.nl)
NS_API_KEY=

# Swedish rail — Trafiklab ResRobot v2.1 (https://www.trafiklab.se)
RESROBOT_API_KEY=

# Uber — deep-link price estimates (optional; tools degrade gracefully without)
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=

# Healthchecks.io UUIDs (optional — set if you want canary + cache-prune to ping)
TRAVEL_HC_UUID=
TRAVEL_CANARY_HC_SCRAPED=
TRAVEL_CANARY_HC_OFFICIAL=
